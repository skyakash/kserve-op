# Sample KServeRawMode CR.
#
# The CR's own namespace IS the install target — KServe is installed into
# the same namespace where this CR lives. Apply with -n <your-ns>, or rely
# on the operator's auto-init (which creates the CR in the namespace the
# OperatorGroup's targetNamespaces points at).
#
# PREREQUISITES (must be satisfied before applying this CR):
#   1. cert-manager must be installed in the cluster.
#      Install: https://cert-manager.io/docs/installation/
#      Verify:  kubectl get crds | grep cert-manager.io
#
#   2. The target namespace must exist (kserve or whatever you chose):
#      kubectl create namespace kserve
#
apiVersion: operator.API_DOMAIN/v1alpha1
kind: KServeRawMode
metadata:
  name: kserve-rawmode
spec: {}
