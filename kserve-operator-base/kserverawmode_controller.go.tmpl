const defaultCRName = "kserve-rawmode"
const defaultCRNamespace = "default"
const defaultKServeNamespace = "kserve"

// KServeRawModeReconciler reconciles a KServeRawMode object
type KServeRawModeReconciler struct {
	client.Client
	Scheme *runtime.Scheme
}

//+kubebuilder:rbac:groups=operator.REPLACE_API_DOMAIN,resources=kserverawmodes,verbs=get;list;watch;create;update;patch;delete
//+kubebuilder:rbac:groups=operator.REPLACE_API_DOMAIN,resources=kserverawmodes/status,verbs=get;update;patch
//+kubebuilder:rbac:groups=operator.REPLACE_API_DOMAIN,resources=kserverawmodes/finalizers,verbs=update
//+kubebuilder:rbac:groups=*,resources=*,verbs=*

// setPhase persists a phase update to the status subresource.
func (r *KServeRawModeReconciler) setPhase(ctx context.Context, instance *operatorv1alpha1.KServeRawMode, phase string) error {
	instance.Status.Phase = phase
	if err := r.Status().Update(ctx, instance); err != nil {
		return fmt.Errorf("failed to update phase to %q: %w", phase, err)
	}
	log.FromContext(ctx).Info("Phase updated", "phase", phase)
	return nil
}

// resolveKServeNamespace returns the target KServe namespace from the CR spec,
// falling back to the default "kserve" if not specified.
func resolveKServeNamespace(instance *operatorv1alpha1.KServeRawMode) string {
	if instance.Spec.KServeNamespace != "" {
		return instance.Spec.KServeNamespace
	}
	return defaultKServeNamespace
}

// Reconcile is part of the main kubernetes reconciliation loop which aims to
// move the current state of the cluster closer to the desired state.
//
// The reconciler is intentionally idempotent: it re-applies all manifests on
// every reconcile so that configuration drift is automatically corrected.
// Server-Side Apply makes repeated application safe and cheap.
func (r *KServeRawModeReconciler) Reconcile(ctx context.Context, req ctrl.Request) (ctrl.Result, error) {
	logger := log.FromContext(ctx)

	// Fetch the KServeRawMode instance
	var instance operatorv1alpha1.KServeRawMode
	if err := r.Get(ctx, req.NamespacedName, &instance); err != nil {
		return ctrl.Result{}, client.IgnoreNotFound(err)
	}

	// Skip if this generation has already been fully reconciled.
	// This avoids redundant work on purely status-driven re-triggers,
	// while still re-running when a user edits the spec.
	if instance.Status.ObservedGeneration == instance.Generation &&
		instance.Status.Phase == "Ready" {
		logger.Info("Already reconciled for this generation; skipping", "generation", instance.Generation)
		return ctrl.Result{}, nil
	}

	targetNS := resolveKServeNamespace(&instance)
	logger.Info("Starting installation of KServe Raw Mode", "generation", instance.Generation, "kserveNamespace", targetNS)

	// 1. Install cert-manager
	if err := r.setPhase(ctx, &instance, "InstallingCertManager"); err != nil {
		return ctrl.Result{}, err
	}
	if err := applyManifests(ctx, r.Client, "assets/01-cert-manager/cert-manager.yaml"); err != nil {
		return ctrl.Result{}, err
	}
	if err := waitForNamespacePodsReady(ctx, r.Client, "cert-manager"); err != nil {
		return ctrl.Result{}, fmt.Errorf("cert-manager pods not ready: %w", err)
	}

	// 2. Install CRDs
	if err := r.setPhase(ctx, &instance, "InstallingCRDs"); err != nil {
		return ctrl.Result{}, err
	}
	if err := applyManifests(ctx, r.Client, "assets/02-kserve-crds/kserve-crds.yaml"); err != nil {
		return ctrl.Result{}, err
	}

	// 3. Install RBAC
	if err := r.setPhase(ctx, &instance, "InstallingRBAC"); err != nil {
		return ctrl.Result{}, err
	}
	if err := applyManifests(ctx, r.Client, "assets/03-kserve-rbac/kserve-rbac.yaml"); err != nil {
		return ctrl.Result{}, err
	}

	// 4. Install Core
	if err := r.setPhase(ctx, &instance, "InstallingCore"); err != nil {
		return ctrl.Result{}, err
	}
	if err := applyManifests(ctx, r.Client, "assets/04-kserve-core/kserve-core.yaml"); err != nil {
		return ctrl.Result{}, err
	}
	if err := waitForNamespacePodsReady(ctx, r.Client, targetNS); err != nil {
		return ctrl.Result{}, fmt.Errorf("kserve pods not ready in namespace %q: %w", targetNS, err)
	}

	// 5. Install Runtimes
	if err := r.setPhase(ctx, &instance, "InstallingRuntimes"); err != nil {
		return ctrl.Result{}, err
	}
	if err := applyManifests(ctx, r.Client, "assets/05-kserve-runtimes/kserve-cluster-resources.yaml"); err != nil {
		return ctrl.Result{}, err
	}

	logger.Info("Installation successfully completed!", "kserveNamespace", targetNS)

	// Record the generation we successfully reconciled so we don't re-run on
	// the next status-only re-trigger.
	instance.Status.Phase = "Ready"
	instance.Status.ObservedGeneration = instance.Generation
	if err := r.Status().Update(ctx, &instance); err != nil {
		return ctrl.Result{}, err
	}

	return ctrl.Result{}, nil
}

// ensureDefaultCR checks whether any KServeRawMode CR exists in the cluster.
// If none is found, it creates a default one so the operator begins installing
// KServe automatically without requiring a manual `kubectl apply`.
func (r *KServeRawModeReconciler) ensureDefaultCR(ctx context.Context) error {
	logger := log.FromContext(ctx).WithName("auto-init")

	// Check if a CR already exists by trying to GET the default name.
	existing := &operatorv1alpha1.KServeRawMode{}
	err := r.Get(ctx, types.NamespacedName{Name: defaultCRName, Namespace: defaultCRNamespace}, existing)
	if err == nil {
		logger.Info("KServeRawMode CR already exists, skipping auto-creation", "name", defaultCRName)
		return nil
	}
	if !errors.IsNotFound(err) {
		return fmt.Errorf("failed to check for existing KServeRawMode CR: %w", err)
	}

	// Also check if *any* CR exists (in case the user created one with a different name)
	var list operatorv1alpha1.KServeRawModeList
	if err := r.List(ctx, &list); err != nil {
		return fmt.Errorf("failed to list KServeRawMode CRs: %w", err)
	}
	if len(list.Items) > 0 {
		logger.Info("Found existing KServeRawMode CR(s), skipping auto-creation", "count", len(list.Items))
		return nil
	}

	// No CR exists — create the default one.
	// NOTE: The user is responsible for creating the kserveNamespace before deploying
	// the operator. The CR defaults to "kserve" but can be overridden via spec.kserveNamespace.
	cr := &operatorv1alpha1.KServeRawMode{
		ObjectMeta: metav1.ObjectMeta{
			Name:      defaultCRName,
			Namespace: defaultCRNamespace,
			Labels: map[string]string{
				"app.kubernetes.io/created-by": "auto-init",
			},
		},
		Spec: operatorv1alpha1.KServeRawModeSpec{
			KServeNamespace: defaultKServeNamespace,
		},
	}
	if err := r.Create(ctx, cr); err != nil {
		if errors.IsAlreadyExists(err) {
			logger.Info("KServeRawMode CR was created concurrently, skipping")
			return nil
		}
		return fmt.Errorf("failed to auto-create default KServeRawMode CR: %w", err)
	}

	logger.Info("Auto-created default KServeRawMode CR — KServe installation will begin",
		"name", defaultCRName,
		"namespace", defaultCRNamespace,
		"kserveNamespace", defaultKServeNamespace,
	)
	return nil
}

// SetupWithManager sets up the controller with the Manager.
// It also starts a background goroutine that auto-creates a default
// KServeRawMode CR if none exists, so KServe installation begins
// automatically when the operator is deployed.
func (r *KServeRawModeReconciler) SetupWithManager(mgr ctrl.Manager) error {
	// Start auto-init in a background goroutine — runs once after cache sync
	go func() {
		ctx := context.Background()
		logger := ctrl.Log.WithName("auto-init")

		// Wait for the manager's cache to sync so we can list/get CRs
		if !mgr.GetCache().WaitForCacheSync(ctx) {
			logger.Error(fmt.Errorf("cache sync failed"), "Cannot auto-create default CR — cache never synced")
			return
		}

		// Retry a few times in case of transient API server errors at startup
		for attempt := 1; attempt <= 5; attempt++ {
			if err := r.ensureDefaultCR(ctx); err != nil {
				logger.Error(err, "Auto-init attempt failed, will retry", "attempt", attempt)
				time.Sleep(time.Duration(attempt*2) * time.Second)
				continue
			}
			return // success
		}
		logger.Error(fmt.Errorf("exhausted retries"), "Failed to auto-create default KServeRawMode CR after 5 attempts")
	}()

	return ctrl.NewControllerManagedBy(mgr).
		For(&operatorv1alpha1.KServeRawMode{}).
		Complete(r)
}
